NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
API_ENABLED=false
API_SOCKET_PATH=
API_BOOTSTRAP_TOKEN=
API_BOOTSTRAP_ACTOR_ID=local-owner
API_BOOTSTRAP_ROLE=OWNER
DATABASE_URL=postgres://praxrail_app:praxrail_app@localhost:5433/praxrail
MIGRATION_DATABASE_URL=postgres://praxrail_migrator:praxrail_migrator@localhost:5433/praxrail
DATABASE_SSL=false
MIGRATIONS_DIR=./migrations
OWNER_TIMEZONE=Africa/Nairobi
DAILY_REPORT_TIME=18:00
TASK_BUDGET_USD=5
DAILY_BUDGET_USD=25
MONTHLY_BUDGET_USD=300
MAX_BUILD_ATTEMPTS=3
MAX_REVIEW_CYCLES=2
JOB_CONCURRENCY=4
JOB_RETRY_LIMIT=3
JOB_RETRY_DELAY_SECONDS=5
WORKSPACE_ROOT=./.praxrail/workspaces
REPOSITORY_ROOT=./.praxrail/repositories
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_ALLOWED_CHAT_IDS=
GITHUB_ENABLED=false
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY_BASE64=
GITHUB_WEBHOOK_SECRET=
GITHUB_ALLOWED_REPOSITORIES=
CODEX_ENABLED=false
CODEX_BUILDER_API_KEY=
CODEX_REVIEWER_API_KEY=
CODEX_MODEL=
CODEX_TIMEOUT_MS=1200000
OTEL_ENABLED=false
OTEL_SERVICE_NAME=praxrail
