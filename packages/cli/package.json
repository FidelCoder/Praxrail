{
  "name": "@praxrail/cli",
  "version": "0.2.0",
  "private": true,
  "description": "Terminal interface for Praxrail.",
  "type": "module",
  "bin": {
    "praxrail": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --root ../.. tests/product-packages.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@praxrail/client": "workspace:*",
    "@praxrail/core": "workspace:*"
  }
}
