{
  "name": "@praxrail/cli",
  "version": "0.3.0",
  "private": false,
  "description": "Terminal interface for Praxrail.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FidelCoder/Praxrail.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "praxrail": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "completions",
    "man"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --root ../.. tests/product-packages.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@praxrail/client": "workspace:*",
    "@praxrail/core": "workspace:*"
  }
}
