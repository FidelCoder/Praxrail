{
  "name": "praxrail",
  "version": "0.3.7",
  "private": false,
  "description": "Terminal interface for Praxrail.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FidelCoder/Praxrail.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "praxrail": "./dist/bin.js",
    "pxr": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run --root ../.. tests/product-packages.test.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "pnpm --dir ../.. artifacts:cli"
  },
  "dependencies": {
    "@octokit/app": "^16.1.2",
    "@octokit/webhooks": "^14.2.0",
    "@openai/codex-sdk": "^0.145.0",
    "croner": "^10.0.1",
    "execa": "^9.6.1",
    "fastify": "^5.10.0",
    "luxon": "^3.7.2",
    "pg": "^8.22.0",
    "pg-boss": "^12.26.0",
    "praxrail-client": "workspace:*",
    "praxrail-core": "workspace:*",
    "prom-client": "^15.1.3",
    "zod": "^4.4.3"
  },
  "files": [
    "README.md",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "runtime/**/*.js",
    "runtime/**/*.js.map",
    "completions",
    "man"
  ]
}
